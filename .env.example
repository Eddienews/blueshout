# Copy to .env for local/systemd deployments. Never commit real secrets.
SECRET_KEY=replace-with-a-random-secret
# Use 1 behind HTTPS in production. Use 0 only for local HTTP development.
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_SAMESITE=Lax

# Flask dev server only
HOST=127.0.0.1
PORT=5000
FLASK_DEBUG=0

# TTS controls
TTS_STRICT_PIPER=1
TTS_RATE_LIMIT=30
TTS_RATE_WINDOW=60
TTS_MAX_CONCURRENT=2
PIPER_BIN=/usr/local/bin/piper
PIPER_MODELS_DIR=/opt/piper/models
# Optional: expose extra language bases beyond the built-in defaults.
# Example: PIPER_LANGUAGES=nl,pl,ja
PIPER_LANGUAGES=
# Optional: override or add specific Piper model base paths without .onnx.
# Example: PIPER_NL=/opt/piper/models/nl_NL-mls-medium
# Example: PIPER_VOICES=nl=/opt/piper/models/nl_NL-mls-medium,pl=/opt/piper/models/pl_PL-darkman-medium
PIPER_VOICES=
